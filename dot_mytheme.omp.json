{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "version": 4,
  "final_space": true,
  "palette": {
    "blueish_grey": "#546E7A",
    "blueish_dark_grey": "#3A3A3A",
    "blueish_light_blue": "#a2beef",
    "blueish_bright_blue": "#14c2dd",
    "blueish_git_blue": "#a2c4e0",
    "blueish_green": "#6CA35E",

    "atomic_blue": "#0077c2",
    "atomic_orange": "#FF9248",

    "cobalt_yellow": "#FFC600",
    "gmay_purple": "#c386f1",
    "jan_orange": "#FEAC19",

    "cert_pink": "#E36464",
    "froczh_purple": "#40189c",
    "pixelrobots_yellow": "#ffea00",
    "plague_red": "#ff0000",
    "iterm_green": "#33DD2D",

    "npm_red": "#CB3837",
    "python_yellow": "#FFDE57",
    "pixelrobots_yellow": "#ffea00",
    "dark_text": "#193549",
    "status_text": "#242424",
    "white": "#ffffff",
    "error": "#ff0000"
  },
  "blocks": [
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [
{
  "type": "text",
  "style": "powerline",
  "leading_powerline_symbol": "\ue0b6",
  "powerline_symbol": "\ue0b4",
  "foreground": "p:pixelrobots_yellow",
  "background": "p:blueish_grey",
  "template": " \ue764 "
},
        {
          "type": "session",
          "style": "powerline",
          "powerline_symbol": "\ue0b4",
          "foreground": "p:white",
          "background": "p:blueish_dark_grey",
          "template": " {{ .UserName }} "
        },
        {
          "type": "path",
          "style": "powerline",
          "powerline_symbol": "\ue0b4",
          "foreground": "p:dark_text",
          "background": "p:blueish_bright_blue",
          "template": " \ue5ff {{ .Path }} ",
          "options": {
            "style": "folder",
            "folder_separator_icon": " \ue0b1 "
          }
        },
        {
          "type": "git",
          "style": "powerline",
          "powerline_symbol": "\ue0b4",
          "foreground": "p:dark_text",
          "background": "p:cobalt_yellow",
          "background_templates": [
            "{{ if or (.Working.Changed) (.Staging.Changed) }}p:atomic_orange{{ end }}",
            "{{ if and (gt .Ahead 0) (gt .Behind 0) }}p:jan_orange{{ end }}",
            "{{ if gt .Ahead 0 }}p:gmay_purple{{ end }}",
            "{{ if gt .Behind 0 }}p:blueish_light_blue{{ end }}"
          ],
          "template": " {{ .UpstreamIcon }}\ue725 {{ .HEAD }}{{ if .BranchStatus }} {{ .BranchStatus }}{{ end }}{{ if gt .Working.Added 0 }} \uf055 {{ .Working.Added }}{{ end }}{{ if gt .Working.Modified 0 }} \uf044 {{ .Working.Modified }}{{ end }}{{ if gt .Working.Deleted 0 }} \uf1f8 {{ .Working.Deleted }}{{ end }}{{ if gt .Working.Untracked 0 }} \uf059 {{ .Working.Untracked }}{{ end }}{{ if gt .Staging.Added 0 }} \uf00c {{ .Staging.Added }}{{ end }}{{ if gt .Staging.Modified 0 }} \uf046 {{ .Staging.Modified }}{{ end }}{{ if gt .Staging.Deleted 0 }} \uf00d {{ .Staging.Deleted }}{{ end }}{{ if gt .StashCount 0 }} \ueb4b {{ .StashCount }}{{ end }} ",
          "options": {
            "branch_template": "{{ trunc 25 .Branch }}",
            "fetch_status": true,
            "fetch_upstream_icon": true,
            "fetch_push_status": true
          }
        },
        {
          "type": "root",
          "style": "powerline",
          "powerline_symbol": "\ue0b4",
          "foreground": "p:dark_text",
          "background": "p:jan_orange",
          "template": " \uf0ad admin "
        }
      ]
    },
    {
      "type": "rprompt",
      "alignment": "right",
      "overflow": "hide",
      "segments": [
        {
          "type": "time",
          "style": "plain",
          "foreground": "p:white",
          "background": "p:cert_pink",
          "template": "<p:cert_pink,transparent>\ue0b6</> \uf017 {{ .CurrentDate | date .Format }} <transparent,p:cert_pink>\ue0b2</>",
          "options": {
            "time_format": "15:04"
          }
        },
        {
          "type": "executiontime",
          "style": "powerline",
          "invert_powerline": true,
          "powerline_symbol": "\ue0b2",
          "foreground": "p:white",
          "background": "p:gmay_purple",
          "template": " \ueba2 {{ .FormattedMs }} ",
          "options": {
            "threshold": 500,
            "style": "roundrock",
            "always_enabled": false
          }
        },
        {
          "type": "node",
          "style": "powerline",
          "invert_powerline": true,
          "powerline_symbol": "\ue0b2",
          "foreground": "p:white",
          "background": "p:blueish_green",
          "template": " \ue718 {{ if .PackageManagerIcon }}{{ .PackageManagerIcon }} {{ end }}{{ .Full }} ",
          "options": {
            "display_mode": "context",
            "fetch_package_manager": true,
            "fetch_version": true,
            "cache_duration": "5m"
          }
        },
        {
          "type": "npm",
          "style": "powerline",
          "invert_powerline": true,
          "powerline_symbol": "\ue0b2",
          "foreground": "p:white",
          "background": "p:npm_red",
          "template": " \ue71e {{ .Full }} ",
          "options": {
            "fetch_version": true,
            "cache_duration": "5m"
          }
        },
        {
          "type": "dotnet",
          "style": "powerline",
          "invert_powerline": true,
          "powerline_symbol": "\ue0b2",
          "foreground": "p:white",
          "background": "p:froczh_purple",
          "template": " \ue648 {{ .Full }} ",
          "options": {
            "display_mode": "context",
            "fetch_version": true,
            "fetch_sdk_version": true,
            "cache_duration": "5m"
          }
        },
        {
          "type": "python",
          "style": "powerline",
          "invert_powerline": true,
          "powerline_symbol": "\ue0b2",
          "foreground": "p:dark_text",
          "background": "p:python_yellow",
          "template": " \ue235 {{ if .Venv }}{{ .Venv }} {{ end }}{{ .Full }} ",
          "options": {
            "display_mode": "context",
            "fetch_virtual_env": true,
            "fetch_version": true,
            "cache_duration": "5m"
          }
        },
        {
          "type": "status",
          "style": "diamond",
          "invert_powerline": true,
          "leading_diamond": "\ue0b2",
          "trailing_diamond": "\ue0b4",
          "foreground": "p:status_text",
          "foreground_templates": [
            "{{ if gt .Code 0 }}p:white{{ end }}"
          ],
          "background": "p:iterm_green",
          "background_templates": [
            "{{ if gt .Code 0 }}p:plague_red{{ end }}"
          ],
          "template": " {{ if gt .Code 0 }}\uf071 {{ .Code }}{{ else }}\uf00c{{ end }} ",
          "options": {
            "always_enabled": true
          }
        }
      ]
    },
    {
      "type": "prompt",
      "alignment": "left",
      "newline": true,
      "segments": [
        {
          "type": "status",
          "style": "plain",
          "foreground": "p:blueish_bright_blue",
          "foreground_templates": [
            "{{ if gt .Code 0 }}p:plague_red{{ end }}"
          ],
          "template": "{{ if gt .Code 0 }}\uf071{{ else }}➜{{ end }} ",
          "options": {
            "always_enabled": true
          }
        }
      ]
    }
  ],
  "console_title_template": "{{ .Shell }} in {{ .Folder }}"
}