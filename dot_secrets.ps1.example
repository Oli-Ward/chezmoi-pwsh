# Example of ~/.secrets.ps1
#
# The PowerShell profile dot-sources ~/.secrets.ps1 if it exists (guarded by
# Test-Path, so it is safe for this file to be absent). The real .secrets.ps1
# is intentionally NOT tracked by git or chezmoi.
#
# To set up secrets on a machine: copy this file to ~/.secrets.ps1 and replace
# the placeholder values below with real ones.

$env:ATLASSIAN_API_TOKEN = "<your-atlassian-api-token>"
